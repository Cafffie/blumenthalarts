import time
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.common.exceptions import TimeoutException, NoSuchElementException

# 1. Initialize data storage
all_seats = []
section_counter = 1

while True:
    print(f"Scraping Section {section_counter}...")
    
    # 2. Wait for the seats in the current section to load
    try:
        WebDriverWait(driver, 10).until(
            EC.presence_of_element_located((By.CLASS_NAME, "seat-element-class"))
        )
    except TimeoutException:
        print(f"No seats found in section {section_counter} or page timed out.")
        break

    # 3. Scrape the current section's seats
    seats = driver.find_elements(By.CLASS_NAME, "seat-element-class")
    for seat in seats:
        # Extract the details you need (e.g., seat number, availability, price)
        seat_data = {
            "section": f"Section {section_counter}",
            "seat_id": seat.get_attribute("id") or seat.text,
            "status": seat.get_attribute("data-status")  # Example: 'available'/'taken'
        }
        all_seats.append(seat_data)

    # 4. Check if the "Next Section" arrow exists and is clickable
    try:
        # Replace with your actual arrow selector
        next_button = driver.find_element(By.ID, "next-section-arrow")
        
        # If the button is disabled on the last section, break the loop
        if "disabled" in next_button.get_attribute("class") or not next_button.is_enabled():
            print("Reached the last section.")
            break
            
        # Click to move to the next section
        next_button.click()
        section_counter += 1
        
        # Small pause to allow the DOM/animation to transition
        time.sleep(1.5) 
        
    except NoSuchElementException:
        # If the arrow isn't found at all, it means there's only 1 section or we are done
        print("Next arrow not found. Scraping finished.")
        break

# 5. Save your scraped data
print(f"Successfully scraped {len(all_seats)} seats total.")
